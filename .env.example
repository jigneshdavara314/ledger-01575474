# ===========================================================================
# Copy this file to ".env" and fill in your values.
#   cp .env.example .env
# ===========================================================================

# --- MODE -------------------------------------------------------------------
# PAPER = simulate trades, no real money (SAFE -- start here)
# LIVE  = place real orders on Polymarket (needs funded wallet below)
MODE=PAPER

# --- RISK PROFILE -----------------------------------------------------------
# conservative | moderate | aggressive
PROFILE=moderate

# --- AI ESTIMATORS (recommended -- one or both) -----------------------------
# Claude Haiku is used for sports/esports where reasoning about context matters.
# If ANTHROPIC_API_KEY is set it takes priority over OpenAI.
ANTHROPIC_API_KEY=

# OpenAI fallback (GPT-4o-mini). Used if Anthropic key is not set.
OPENAI_API_KEY=

# --- SHORT-TERM MARKET TARGETING --------------------------------------------
# Only look at markets resolving within this many hours (sports/esports = fast)
MAX_HOURS=48

# Comma-separated list of categories to scan.
# Options: soccer, esports, tennis, nba, mlb, nfl, ufc, golf, crypto, politics, other
CATEGORIES=soccer,esports,tennis,nba,ufc,crypto

# Daily profit goal (display only -- bot does not auto-stop at this number)
DAILY_TARGET=500

# --- WALLET (only needed for MODE=LIVE) -------------------------------------
# Private key of a Polygon wallet funded with USDC.
# NEVER share this or commit it. Keep .env out of git.
POLYGON_WALLET_PRIVATE_KEY=

# --- TUNING (optional, defaults are fine) -----------------------------------
SCAN_INTERVAL=60
MARKET_LIMIT=30
